{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && node --env-file=../../.env --enable-source-maps ./dist/index.mjs",
    "build": "node ./build.mjs",
    "start": "node --env-file=./.env --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "ready": "tsx specs/checkReadiness.ts",
    "test": "vitest",
"lint": "eslint \"src/**/*.ts\" --fix",
  "test:ui":"vitest --ui --open"
  },
  "dependencies": {
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "aes-js": "^4.0.0-beta.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "ethers": "^6.16.0",
    "express": "^5",
    "node-fetch": "^3.3.2",
    "openai": "4.52.7",
    "pino": "^9",
    "pino-http": "^10",
    "socket.io": "^4.8.3",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@vitest/ui": "^2.0.5",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "jsdom": "^25.0.1",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "^4.21.0",
    "vitest": "^2.0.5"
  }
}
