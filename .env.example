# BrightSky Environment Template
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/brightsky

# RPC
RPC_ENDPOINT=https://base.llamarpc.com

# Auth
API_KEY=your_api_key_here
CORS_ORIGINS=http://localhost:3000,https://your-ui-domain.com

# Trading
PIMLICO_API_KEY=pim_your_key
PRIVATE_KEY=0x_your_private_key
WALLET_ADDRESS=0x_your_wallet

# Optional
OPENAI_API_KEY=sk_your_key
CHAIN_ID=8453
