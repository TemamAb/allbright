{
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "allbright",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {},
    "bundle": {
      "active": true,
      "identifier": "com.allbright.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Allbright Arbitrage",
        "width": 1200,
        "height": 800
      }
    ]
  }
}
