{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Allbright",
  "version": "0.2.6",
  "identifier": "com.allbright.desktop",
  "build": {
    "beforeDevCommand": "powershell -Command \"Set-Location ../ui; npm run dev\"",
    "beforeBuildCommand": "powershell -Command \"Set-Location ../ui; npm run build\"",
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Allbright",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/allbright_32x32.png",
      "icons/allbright_128x128.png",
      "icons/allbright_icon.ico"
    ]
  }
}