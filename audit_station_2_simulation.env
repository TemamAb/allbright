# ==========================================
# STATION 2: LIVE SIMULATION AUDIT CONFIGURATION
# ==========================================
# This environment file is used to run a paper-trading/simulation 
# environment to audit trading logic and MEV protection securely.

NODE_ENV=production
PAPER_TRADING_MODE=true
MEV_PROTECTION=true

# Vite UI Configuration
VITE_API_BASE_URL=http://localhost:3001
VITE_AUDIT_MODE_ENABLED=true
VITE_SIMULATION_ACTIVE=true

# API Server Config
PORT=3001
DATABASE_URL=postgres://audit_user:audit_pass@localhost:5432/audit_sim_db
APP_INITIAL_SETUP=false
PRE_FLIGHT_STRICT=false

# Use testnet or fork RPCs
CHAIN_ID=8453
RPC_ENDPOINT=https://base-sepolia.publicnode.com
ETH_RPC_URL=https://ethereum-sepolia.publicnode.com
BASE_RPC_URL=https://base-sepolia.publicnode.com

# Dummy keys (Replace with simulation/testnet keys)
JWT_SECRET=audit_simulation_secret
PIMLICO_API_KEY=your_testnet_pimlico_key
WALLET_ADDRESS=your_testnet_wallet
PRIVATE_KEY=your_testnet_private_key
PROFIT_WALLET_ADDRESS=your_testnet_wallet

# Rust Solver Config
RUST_LOG=info
USE_TCP_BRIDGE=true
allbright_TCP_HOST=localhost
allbright_TCP_PORT=10000
