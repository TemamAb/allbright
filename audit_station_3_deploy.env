# ==========================================
# STATION 3: DEPLOYING & MONITORING AUDIT CONFIG
# ==========================================
# This environment file acts as a template for connecting the local 
# Tauri desktop application to monitor the remote production deployment.

NODE_ENV=production

# Vite UI Configuration
VITE_API_BASE_URL=https://allbright-api.onrender.com
VITE_AUDIT_MODE_ENABLED=true
VITE_MONITORING_ACTIVE=true

# Remote Database Access (Read-Only auditing connection recommended)
DATABASE_URL=postgres://remote_audit_user:password@remote-db-host/allbright-db

# Ensure these match production configurations for accurate auditing
CHAIN_ID=8453
RPC_ENDPOINT=https://base.llamarpc.com
MEV_PROTECTION=true

# Provide real API keys ONLY if required for remote monitoring
# NEVER commit this file if it contains real keys.
JWT_SECRET=your_production_secret
PIMLICO_API_KEY=your_production_pimlico_key
WALLET_ADDRESS=your_production_wallet
PRIVATE_KEY=your_production_private_key
PROFIT_WALLET_ADDRESS=your_production_profit_wallet

# Rust Solver Config
RUST_LOG=warn
USE_TCP_BRIDGE=true
allbright_TCP_HOST=allbright-solver
allbright_TCP_PORT=10000
