{
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "publisher": "Allbright",
    "copyright": "Copyright © 2024 Allbright - AI-Agent Trading Terminal",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [
      "bin/allbright"
    ],
    "category": "Finance",
    "shortDescription": "Allbright AI-Agent Desktop Trading Terminal",
    "longDescription": "Production-grade desktop trading terminal with AI-agent arbitrage solver, deployment readiness checks, and multi-stage workflow management.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "createUpdaterArtifacts": false
  },
    "build": {
      "beforeDevCommand": "pnpm start",
      "beforeBuildCommand": "pnpm build",
      "frontendDist": "../build",
      "devUrl": "http://localhost:1420"
    },
  "productName": "Allbright Desktop",
  "mainBinaryName": "allbright-desktop",
  "version": "0.2.6",
  "identifier": "com.allbright.desktop",
   "plugins": {
     "updater": {
       "endpoints": [
         "https://releases.allbright.ai/desktop/{{target}}/{{arch}}"
       ],
       "pubkey": ""
     }
   },
  "app": {
    "security": {
      "csp": "default-src blob: data: filesystem: ws: wss: http: https: tauri: 'unsafe-eval' 'unsafe-inline' 'self' img-src: 'self'; connect-src ipc: http://ipc.localhost"
    },
    "windows": [
      {
        "title": "Allbright AI-Agent Desktop",
        "label": "main",
        "minWidth": 1000,
        "minHeight": 600,
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "decorations": true,
        "alwaysOnTop": false,
        "useHttpsScheme": true
      }
    ],
    "withGlobalTauri": false
  }
}
