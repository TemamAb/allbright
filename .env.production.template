# Allbright Production Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ===================
# CORE SERVICES
# ===================

# PostgreSQL Database URL
# Format: postgresql://user:password@host:5432/allbright
DATABASE_URL=

# RPC Endpoint (Base mainnet)
# Recommended: https://base.llamarpc.com or https://1rpc.io/base
RPC_ENDPOINT=

# ===================
# PIMLICO (GASLESS)
# ===================

PIMLICO_API_KEY=

# ===================
# PRIVATE KEY (DEPLOYER)
# ===================

# WARNING: Use a deployer wallet with limited funds for security
# Format: 0x... (without 0x prefix for some configs)
PRIVATE_KEY=

# ===================
# FLASHBOTS (MEV PROTECTION)
# ===================

FLASHBOTS_RPC_URL=

# ===================
# APPLICATION CONFIG
# ===================

NODE_ENV=production
PORT=3000

# Frontend API URL (required for production builds)
VITE_API_BASE_URL=
