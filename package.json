{
  "name": "allbright-workspace",
  "private": true,
  "main": "main.js",
  "scripts": {
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "typecheck:libs": "tsc --build",
    "dev": "pnpm --parallel --filter ... dev",
    "build": "pnpm -r build",
    "readiness": "npx tsx api/specs/checkReadiness.ts",
    "electron:dev": "concurrently \"pnpm dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "pnpm build && electron-builder"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.0",
    "nodemailer": "^6.9.13",
    "node-cron": "^3.0.3",
    "wagmi": "^2.12.0",
    "viem": "^2.21.0",
    "@web3modal/wagmi": "^5.1.0",
    "@tanstack/react-query": "^5.59.0",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/pdfkit": "^0.13.4",
    "@types/nodemailer": "^6.4.14",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0",
    "concurrently": "^8.2.2"
  },
  "packageManager": "pnpm@9.12.2",
  "pnpm": {
   "overrides": {
     }
  }
}
