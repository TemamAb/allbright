{
  "name": "allbright-workspace",
  "version": "0.2.6",
  "private": true,
  "main": "main.js",
  "scripts": {
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "typecheck:libs": "tsc --build",
    "dev": "vite",
    "build": "pnpm -r build",
    "readiness": "npx tsx api/specs/checkReadiness.ts",
    "electron:dev": "concurrently \"pnpm dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@tauri-apps/api": "^2.11.0",
    "@web3modal/wagmi": "^5.1.0",
    "bcryptjs": "^2.4.3",
    "ethers": "^6.13.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "pdfkit": "^0.15.0",
    "viem": "^2.21.0",
    "wagmi": "^2.12.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.13.4",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "wait-on": "^7.2.0"
  },
  "packageManager": "pnpm@9.12.2",
  "pnpm": {
    "overrides": {}
  }
}
